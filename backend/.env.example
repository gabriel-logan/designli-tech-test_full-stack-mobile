NODE_ENV=development
SERVER_PORT=3000
ALLOWED_ORIGINS=*

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=designli
POSTGRES_MAX_CONNECTIONS=10
POSTGRES_IDLE_TIMEOUT_MILLIS=60000
POSTGRES_SSL_MODE=false
POSTGRES_CHANNEL_BINDING=false

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d

FINNHUB_API_KEY=your_finnhub_api_key
FINNHUB_DEFAULT_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,TSLA
STOCK_PRICE_POLL_INTERVAL_MS=5000
FINNHUB_QUOTE_REFRESH_INTERVAL_MS=60000

# Firebase Admin SDK service account JSON as a single-line string.
FIREBASE_SERVICE_ACCOUNT_JSON=
